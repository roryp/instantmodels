FOUNDRY_PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_MODEL=gpt-chat-latest
FOUNDRY_PROMPT=In one sentence, what are instant models in Microsoft Foundry?

# Optional live Azure Retail Prices API lookup settings.
FOUNDRY_PRICING_REGION=westus3
FOUNDRY_PRICING_CURRENCY=USD
FOUNDRY_PRICING_SCOPE=Gl

# Optional when a model alias needs a specific retail meter prefix.
# FOUNDRY_PRICING_METER_PREFIX=5.5 ShortCo